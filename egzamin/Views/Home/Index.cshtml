@model Reservation

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/styl_1.css">
    <title>Restaurajca wszystkie smaki</title>
</head>
<body>
    <div class="container">
        <header>
            <h1>Witamy w restauracji „Wszystkie Smaki”</h1>
        </header>
        <main class="container">
            <div class="row">
                <div class="left"><img src="~/menu.jpg" alt="Nasze danie"></div>
                <span class="right">
                    <h4>U nas dobrze zjesz!</h4>
                    <ol>
                        <li>Obiady od 40 zł</li>
                        <li>Przekąski od 10 zł</li>
                        <li>Kolacje od 20 zł</li>
                    </ol>
                </span>
            </div>
            <span class="bottom container centered">
                <h2>Zarezerwuj stolik on-line</h2>
                <form asp-action="Reserve" method="post" class="container centered">
                    <label>Data (format rrrr-mm-dd):</label>
                    <input type="text" asp-for="Date">
                    <label for="">Ile osób:</label>
                    <input type="number" asp-for="PeopleCount">
                    <label for="">Twój numer telefonu:</label>
                    <input type="text" asp-for="PhoneNumber">
                    <div class="row">
                        <input type="checkbox">
                        <label for="">Zgadzam się na przetwarzanie moich danych osobowych</label>
                    </div>
                    <div class="row fit-content"><button type="reset">WYCZYŚĆ</button><button type="submit">REZERWUJ</button></div>
                </form>
            </span>
        </main>
        <footer>
            Stronę internetową opracował: 000000000
        </footer>
    </div>
</body>
</html>